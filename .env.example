# =============================================================================
# Health Companion – Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# DO NOT commit .env to source control.
#
# Variable placement:
#   [Railway]  → set in the Railway service's "Variables" panel
#   [Vercel]   → set in the Vercel project's "Environment Variables" settings
#   [local]    → only needed for local development (already set by dev tooling or
#                inherited from the Manus sandbox environment)
# =============================================================================


# -----------------------------------------------------------------------------
# BACKEND (Express / Railway)
# All of these are server-only – never expose them to the browser.
# -----------------------------------------------------------------------------

# [Railway] MySQL / PlanetScale / any managed MySQL-compatible database URL.
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@host:3306/health_companion

# [Railway] Secret used to sign and verify session JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# [Railway] Manus OAuth server base URL.
OAUTH_SERVER_URL=https://oauth.manus.space

# [Railway] OAuth application ID registered in the Manus developer portal.
VITE_APP_ID=your-manus-app-id

# [Railway] Open ID of the project owner (used for admin notifications).
OWNER_OPEN_ID=owner-open-id

# [Railway] Public URL of the deployed Vercel frontend. Used to redirect the
# browser back to the app after the OAuth web callback completes.
# Example: https://health-companion.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# [Railway] (Optional) Manus Forge API base URL for LLM / image / data features.
BUILT_IN_FORGE_API_URL=

# [Railway] (Optional) Manus Forge API authentication key.
BUILT_IN_FORGE_API_KEY=


# -----------------------------------------------------------------------------
# FRONTEND (Expo / Vercel)
# Variables prefixed with EXPO_PUBLIC_ are inlined at build time and visible
# in the browser bundle – do NOT put secrets here.
# -----------------------------------------------------------------------------

# [Vercel] Absolute URL of the Railway backend API, without a trailing slash.
# Required in production; the app cannot reach the backend without this.
# Example: https://health-companion-api.up.railway.app
EXPO_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app

# [Vercel] Manus OAuth portal URL (where users sign in).
EXPO_PUBLIC_OAUTH_PORTAL_URL=https://portal.manus.space

# [Vercel] Manus OAuth server URL (used by the client to initiate auth).
EXPO_PUBLIC_OAUTH_SERVER_URL=https://oauth.manus.space

# [Vercel] OAuth application ID (same value as VITE_APP_ID on the backend).
EXPO_PUBLIC_APP_ID=your-manus-app-id

# [Vercel] Open ID of the project owner (shown in the UI / used for owner features).
EXPO_PUBLIC_OWNER_OPEN_ID=owner-open-id

# [Vercel] Display name of the project owner.
EXPO_PUBLIC_OWNER_NAME=Owner Name


# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT ONLY
# These are set automatically by the Manus sandbox or the local dev scripts.
# You normally do not need to set them manually.
# -----------------------------------------------------------------------------

# Port for the Metro bundler (Expo web). Defaults to 8081.
# EXPO_PORT=8081

# Port for the Express API server. Defaults to 3000.
# PORT=3000

# Used by the OAuth callback to redirect back to the Expo dev server.
# Only needed if you are testing OAuth locally outside of the Manus sandbox.
# EXPO_WEB_PREVIEW_URL=http://localhost:8081
